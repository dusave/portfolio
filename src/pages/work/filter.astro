---
import Base from '../../layouts/Base.astro';
import FilterDemo from '../../components/FilterDemo.tsx';
import { ChevronLeft, ArrowUpRight } from 'lucide-react';

const sections = [
  {
    h: 'The problem',
    b: 'Structured search is powerful but unforgiving — one malformed qualifier and a user gets nothing back, with no idea why. The component had to make a complex query language feel approachable: parse intent in real time, validate before submission, and teach the syntax through suggestion rather than documentation.',
  },
  {
    h: 'Design evolution',
    b: 'What began as a single input grew through several deliberate passes — tightening the tokenization model, streamlining the validation feedback so errors read as guidance, and reducing visual noise until the interface disappeared behind the task. Each iteration removed more than it added.',
  },
  {
    h: 'Adapting to new requirements',
    b: 'New qualifiers, value types, and product surfaces arrive continuously. The architecture had to absorb them without regressions — so the parser, validation rules, and suggestion engine are decoupled, letting new capabilities land as data, not rewrites.',
  },
  {
    h: 'Ownership',
    b: 'Primary developer & designer — I architected the parsing model, accessibility, and the test strategy (unit, VRT, and end-to-end), and wrote roughly 95% of the code. A small team contributes on rare occasion, but I own it front-to-back and keep 500K+ daily queries reliable.',
  },
];

const tech = ['React', 'TypeScript', 'Relay / GraphQL', 'Primer', 'Storybook', 'Jest · RTL', 'fzy.js', 'Playwright (E2E)', 'VRT'];
---

<Base title="The Filter Component — Dustin Savery" description="An advanced query & validation component at GitHub, handling 450K–550K queries a day.">
  <div class="wrap wrap--narrow">
    <nav class="rise" style="padding:30px 0">
      <a class="lk label" href="/"><ChevronLeft size={14} /> Dustin Savery / Work</a>
    </nav>

    <header class="cs-header">
      <p class="rise label" style="animation-delay:.1s;margin-bottom:22px">GitHub · Staff Frontend Engineer</p>
      <h1 class="rise serif cs-title" style="animation-delay:.2s">
        The Filter<br />Component<span style="color:var(--accent)">.</span>
      </h1>
      <p class="rise cs-sub" style="animation-delay:.35s">
        An advanced querying &amp; validation component —
        <span class="serif-i" style="color:var(--ink);font-size:17px">designed &amp; built as its primary developer.</span>
        It ships in the open — on every repository's issues page and the global issues dashboard.
      </p>
    </header>

    <!-- STAT -->
    <div class="reveal stat">
      <div class="stat-item">
        <span class="serif stat-num" data-count="500000" data-suffix="+">500,000+</span>
        <span class="label" style="max-width:200px">queries handled per day · 450K–550K sustained</span>
      </div>
      <div class="stat-item">
        <span class="serif stat-num" data-count="14">14</span>
        <span class="label" style="max-width:200px">teams across GitHub building on it today</span>
      </div>
    </div>

    <!-- LIVE DEMO -->
    <div class="reveal">
      <p class="label" style="margin-bottom:14px">— Live recreation · try it</p>
      <FilterDemo client:visible />
      <p class="demo-caption">
        An interactive explainer of the parsing &amp; validation logic — the code is proprietary, but you can use the
        real thing live on any repository's issues page.
      </p>
      <a class="try-live" href="https://github.com/issues" target="_blank" rel="noreferrer">
        Try it live on GitHub <ArrowUpRight size={16} />
      </a>
    </div>

    <!-- NARRATIVE -->
    <div class="narrative">
      {sections.map((s) => (
        <div class="reveal narrative-row">
          <h2 class="serif" style="font-size:26px;margin:0;line-height:1.1">{s.h}</h2>
          <p class="narrative-body">{s.b}</p>
        </div>
      ))}
    </div>

    <!-- TECH -->
    <div class="reveal" style="margin-top:9vh">
      <p class="label" style="margin-bottom:16px">— Built with</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px">
        {tech.map((t) => <span class="chip">{t}</span>)}
      </div>
    </div>

    <footer class="cs-footer label">
      <a class="lk" href="/"><ChevronLeft size={14} /> Back to work</a>
      <a class="lk" href="mailto:dustin@savery.io">Get in touch <ArrowUpRight size={14} /></a>
    </footer>
  </div>
</Base>

<style>
  .cs-header { padding-top: 6vh; padding-bottom: 5vh; }
  .cs-title { font-size: clamp(44px, 8vw, 84px); line-height: 0.95; margin: 0; letter-spacing: -0.01em; }
  .cs-sub { color: var(--dim); margin-top: 26px; max-width: 520px; line-height: 1.7; font-size: 14.5px; }

  .stat { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 40px 0; margin: 2vh 0 6vh; display: flex; gap: 48px; flex-wrap: wrap; }
  .stat-item { display: flex; align-items: baseline; gap: 18px; flex-wrap: wrap; }
  .stat-num { font-size: clamp(48px, 10vw, 96px); line-height: 1; color: var(--accent); }

  .demo-caption { color: var(--dim); font-size: 11px; margin-top: 10px; line-height: 1.6; }
  .try-live { display: inline-flex; align-items: center; gap: 8px; margin-top: 18px; padding: 12px 20px; border: 1px solid var(--accent); border-radius: 6px; color: var(--accent); text-decoration: none; font-size: 13px; letter-spacing: 0.02em; transition: background 0.2s, color 0.2s; }
  .try-live:hover { background: var(--accent); color: #101011; }

  .narrative { margin-top: 9vh; display: grid; gap: 7vh; }
  .narrative-row { display: grid; grid-template-columns: minmax(0, 160px) 1fr; gap: 24px; }
  .narrative-body { color: var(--dim); line-height: 1.8; font-size: 14px; margin: 0; }

  .cs-footer { border-top: 1px solid var(--line); margin-top: 10vh; padding: 26px 0 60px; display: flex; justify-content: space-between; align-items: center; }

  @media (max-width: 560px) {
    .narrative-row { grid-template-columns: 1fr; gap: 10px; }
  }
</style>
