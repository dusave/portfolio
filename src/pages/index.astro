---
import Base from '../layouts/Base.astro';
import { site, work, experience, skills } from '../data/site';
import { Github, Linkedin, Globe, Mail, ArrowUpRight } from 'lucide-react';

const isExternal = (href: string) => href.startsWith('http');
---

<Base>
  <div class="wrap">
    <!-- NAV -->
    <nav class="rise nav">
      <span class="serif" style="font-size:22px">DS</span>
      <div class="nav-links label">
        <a class="lk underline-grow" href="#work">Work</a>
        <a class="lk underline-grow" href="#experience">Experience</a>
        <a class="lk underline-grow" href="#contact">Contact</a>
      </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <p class="rise label" style="animation-delay:.15s;margin-bottom:26px">
        {site.location} · {site.role}
      </p>
      <h1 class="rise serif hero-name" style="animation-delay:.25s">
        Dustin<br />Savery<span style="color:var(--accent)">.</span>
      </h1>
      <p class="rise hero-intro" style="animation-delay:.42s">
        Frontend engineer, <span class="serif-i" style="color:var(--ink);font-size:17px">twenty years</span>
        of building for web, desktop &amp; mobile. I sweat the design details so the
        experience feels intuitive &amp; quietly delightful.
      </p>
      <div class="rise socials" style="animation-delay:.55s">
        <a class="lk" href={site.links.github} target="_blank" rel="noreferrer" aria-label="GitHub"><Github size={20} /></a>
        <a class="lk" href={site.links.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn"><Linkedin size={20} /></a>
        <a class="lk" href={site.links.website} target="_blank" rel="noreferrer" aria-label="Website"><Globe size={20} /></a>
        <a class="lk" href={`mailto:${site.email}`} aria-label="Email"><Mail size={20} /></a>
      </div>
    </header>

    <!-- SELECTED WORK -->
    <section id="work" class="section">
      <p class="reveal label section-label">— Selected Work</p>
      {work.map((w) => {
        const Tag = w.href ? 'a' : 'div';
        return (
        <Tag
          class={`row reveal work-row${w.href ? '' : ' work-row--static'}`}
          href={w.href || undefined}
          target={w.href && isExternal(w.href) ? '_blank' : undefined}
          rel={w.href && isExternal(w.href) ? 'noreferrer' : undefined}
        >
          <div class="work-head">
            <h3 class="serif" style={`margin:0;line-height:1.05;font-size:${w.feature ? 'clamp(26px,4vw,40px)' : 'clamp(22px,3vw,30px)'}`}>
              {w.title} {w.href && <ArrowUpRight className="arrow" size={18} style={{ display: 'inline', verticalAlign: 'middle' }} />}
            </h3>
            <span class="label" style="white-space:nowrap">{w.year}</span>
          </div>
          <span class="label" style="color:var(--accent);display:block;margin-top:12px">{w.tag}</span>
          <p class="work-blurb">{w.blurb}</p>
        </Tag>
        );
      })}
      <div style="border-top:1px solid var(--line)"></div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="section">
      <p class="reveal label section-label">— Experience</p>
      {experience.map((e) => (
        <div class="row reveal exp-row">
          <div>
            <div class="exp-head">
              <span class="serif" style="font-size:26px">{e.co}</span>
              <span class="label">{e.role}</span>
            </div>
            <p class="exp-note">{e.note}</p>
          </div>
          <div style="text-align:right">
            <div class="label" style="color:var(--ink)">{e.when}</div>
            <div class="label" style="margin-top:6px">{e.where}</div>
          </div>
        </div>
      ))}
      <div style="border-top:1px solid var(--line)"></div>
    </section>

    <!-- TOOLKIT -->
    <section class="section">
      <p class="reveal label section-label">— Toolkit</p>
      <div class="reveal chips">
        {skills.map((s) => <span class="chip">{s}</span>)}
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section">
      <p class="reveal label" style="margin-bottom:18px">— Get in touch</p>
      <a class="reveal serif underline-grow contact-mail" href={`mailto:${site.email}`}>{site.email}</a>
      <p class="reveal contact-note">
        Open to conversations about frontend platform, design systems &amp; the craft of UI.
      </p>
    </section>

    <footer class="footer label">
      <span>© {new Date().getFullYear()} {site.name}</span>
      <span>Résumé available upon request</span>
      <span>Built with Astro &amp; React · open source</span>
    </footer>
  </div>
</Base>

<style>
  .nav { display: flex; justify-content: space-between; align-items: center; padding: 30px 0; }
  .nav-links { display: flex; gap: 22px; }

  .hero { padding-top: 9vh; padding-bottom: 12vh; }
  .hero-name { font-size: clamp(56px, 11vw, 128px); line-height: 0.92; letter-spacing: -0.01em; margin: 0; }
  .hero-intro { max-width: 460px; margin-top: 30px; color: var(--dim); line-height: 1.7; font-size: 14.5px; }
  .socials { display: flex; gap: 18px; margin-top: 34px; }

  .section { padding-bottom: 10vh; }
  .section-label { margin-bottom: 30px; }

  .work-row { padding: 30px 0; }
  .work-row--static { cursor: default; }
  .work-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .work-blurb { color: var(--dim); margin-top: 12px; max-width: 560px; line-height: 1.65; font-size: 13.5px; }

  .exp-row { padding: 24px 0; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: baseline; }
  .exp-head { display: flex; gap: 12px; align-items: baseline; flex-wrap: wrap; }
  .exp-note { color: var(--dim); margin-top: 8px; max-width: 540px; line-height: 1.6; font-size: 13px; }

  .chips { display: flex; flex-wrap: wrap; gap: 10px; }

  .contact-mail { font-size: clamp(34px, 7vw, 76px); line-height: 1; color: var(--ink); text-decoration: none; display: inline-block; }
  .contact-note { color: var(--dim); margin-top: 26px; font-size: 12.5px; line-height: 1.8; max-width: 520px; }

  .footer { border-top: 1px solid var(--line); padding: 26px 0 50px; display: flex; justify-content: space-between; gap: 12px; }

  @media (max-width: 560px) {
    .exp-row { grid-template-columns: 1fr; }
    .exp-row > div:last-child { text-align: left !important; }
    .footer { flex-direction: column; }
  }
</style>
